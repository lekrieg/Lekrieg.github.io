---
import BaseLayout from '../layouts/BaseLayout.astro';

// ========================================
// ADD YOUR PROJECTS HERE
// Just copy an object and change the fields
// ========================================
const projects = [
  {
    title: 'Project One',
    description: 'Description of your first project. What does it do? What did you learn?',
    tech: ['C++', 'OpenGL'],
    link: 'https://github.com/yourusername/project-one',
    image: '/projects/project1.png', // optional, put image in public/projects/
  },
  {
    title: 'Project Two',
    description: 'Description of your second project.',
    tech: ['C#', 'Unity'],
    link: 'https://github.com/yourusername/project-two',
  },
  {
    title: 'Project Three',
    description: 'Description of your third project.',
    tech: ['Python', 'Pygame'],
    link: 'https://github.com/yourusername/project-three',
  },
];
---

<BaseLayout current="Projects" title="Projects — Daniel Henrique">
  <h1>🎮 Projects</h1>
  <p>A collection of things I've built. Click any card to view the source on GitHub.</p>

  <div class="projects-grid">
    {projects.map((project) => (
      <a href={project.link} class="project-card" target="_blank" rel="noopener">
        {project.image && (
          <img src={project.image} alt={project.title} class="project-image" />
        )}
        <div class="project-body">
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.description}</p>
          <div class="project-tech">
            {project.tech.map(t => <span class="tech-tag">{t}</span>)}
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-bright);
    overflow: hidden;
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s ease;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-2), var(--accent));
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-3px);
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(212, 175, 55, 0.1);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-image {
    width: 100%;
    height: 140px;
    object-fit: cover;
    image-rendering: pixelated;
    border-bottom: 1px solid var(--border);
  }

  .project-body {
    padding: 1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .project-title {
    font-family: var(--font-medieval);
    font-size: 1.3rem;
    color: var(--text-bright);
    margin-bottom: 0.4rem;
  }

  .project-card:hover .project-title {
    color: var(--accent-glow);
  }

  .project-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .project-tech {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tech-tag {
    background: var(--bg-deep);
    color: var(--accent-2-glow);
    font-family: var(--font-retro);
    font-size: 0.95rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border-bright);
  }
</style>
