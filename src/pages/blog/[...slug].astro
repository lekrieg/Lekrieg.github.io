---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

// Esta função diz pro Astro: "gere uma página para cada post"
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },    // /blog/my-first-post
    props: { post },              // passa o post como prop
  }));
}

// Astro pega o post que foi passado pelo getStaticPaths
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout current="Blog" title={`${post.data.title} — Daniel Henrique`}>
  <a href="/blog" class="back-link">◂ Back to Journal</a>

  <article>
    <span class="post-category">{post.data.category}</span>
    <h1>{post.data.title}</h1>
    <div class="post-info">
      <span class="post-date">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </span>
      <span class="tags">
        {post.data.tags.map(tag => <span class="tag">#{tag}</span>)}
      </span>
    </div>

    <hr />

    <div class="post-body">
      <Content />
    </div>

    <hr />
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .post-category {
    display: inline-block;
    background: var(--bg-deep);
    color: var(--accent);
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--accent-2);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .post-info {
    display: flex;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .tags {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--accent-2-glow);
  }
</style>
