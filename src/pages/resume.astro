---
import BaseLayout from '../layouts/BaseLayout.astro';

// ========================================
// EDIT YOUR RESUME DATA HERE
// To add more entries, just add objects to the arrays
// ========================================
const resume = {
  experience: [
    {
      role: 'Systems development analyst II',
      company: 'Radek Systems / Confidencial',
      period: 'Oct 2024 — Present',
      description: '
      - Improved UI/UX and optimized the frontend of an image recognition application using Avalonia UI and PySide6, with a backend built in C# and Python leveraging OpenCV, resulting in a 70% visual improvement across the application.
      - Implemented new features for a cross-platform desktop application (Windows and macOS), focusing on application evolution and performance improvements using C# and Avalonia UI.
      - Developed new Avalonia UI components for internal use across teams.
      ',
    },
    {
      role: 'Full-stack Developer',
      company: 'VERION Oleohidraulica BRASIL',
      period: 'Jan 2024 — Sep 2024',
      description: '
      - Migration of Android (Xamarin) and WPF applications to Avalonia UI, always focusing on optimization and visual improvements to bring the designer’s vision to life.
      - Developed proof of concepts (POCs) to evaluate and validate new technologies.
      - Led a team responsible for building reusable components, reducing development time by at least 50% and enabling developers to focus on screen implementation.
      - Managed projects, ensuring timely delivery and alignment with business goals.
      ',
    },
    {
      role: 'Game Developer',
      company: 'MoyaGames Ltd.',
      period: 'May 2023 — Jan 2024',
      description: '
      Game programming and code optimization in general, using Unity as game engine

      - Implemented an event-based input system using Unity's new input system
      - I improved the performance of some parts of the game by creating some pools of objects, which drastically improved part of the performance bottleneck that existed
      - Improved some gameplay systems (obstacles and stuff like that)
      - Implemented movement through the game menus
      - System of objectives by level
      - Refactoring of some already implemented parts of some systems
      - Steamworks configuration on the project with achievements and leaderboards
      - Implemented a new save system, using Visitor pattern, so we can have multiple versions of the save game and the game don't break if we changeg something.
      ',
    },
    {
      role: 'Software Engineer',
      company: 'CI&T',
      period: 'Feb 2021 — Apr 2023',
      description: '
      - I worked on the implementation of microservices and monolithic applications in fintechs and openbanking
      - Helped with building lambdas in Python in AWS with communication via queue using Kafka
      - Assisted the client in their digital transformation
      - Used Scrum, Kanban and Lean as agile methodologies
      - Helped with the standardization of unit tests
      - I helped with the creation of some POCs and created some others (speed testing of the Gzip and Brotli algorithms and tested the addition of the dotnet benchmark to the project)
      - I gave presentations on game development, design patterns and the difference between microservices and monolithic applications
      - Made improvements to the loading of EntityConfiguration classes in the DbContext using Configurations.AddFromAssembly in which I reduced from 15 lines of code to 2 and avoided the wrong or duplicate addition of configurations classes in the DBContext
      - Assisted QAs in the test executions and created some tools to extract info from unit test to use in the test piramid
      - I helped with the development of some pages in one of the clients systems using Angular and Typescript and made small improvements to the code logic (loading components, etc.)
      ',
    },
  ],
  education: [
    {
      degree: 'B.S. in Analysis and systems development',
      school: 'UniCesumar',
      period: '2020 — 2023',
      description: 'Focus on software programming.',
    },
  ],
  skills: {
    'Languages': ['C++', 'C#', 'Python', 'Java'],
    'Graphics': ['OpenGL'],
    'Engines': ['Unity', 'Godot', 'My custom game engine'],
    'Tools': ['Git', 'Blender', 'CMake', 'Rider', 'Clion'],
    'Management': ['Jira', 'Azure boards', 'Trello', 'Asana', 'Clickup'],
  },
};
---

<BaseLayout current="Resume" title="Resume — Daniel Henrique">
  <h1>📜 Resume</h1>

  <!-- Download link — put your resume PDF in public/resume.pdf -->
  <p class="download-link">
    <a href="/resume.pdf" download>
      ⬇ Download Full Resume (PDF)
    </a>
  </p>

  <h2>⚔ Experience</h2>
  {resume.experience.map(job => (
    <div class="resume-item">
      <div class="resume-header">
        <h3>{job.role}</h3>
        <span class="company">{job.company}</span>
      </div>
      <span class="period">{job.period}</span>
      <p>{job.description}</p>
    </div>
  ))}

  <h2>🎓 Education</h2>
  {resume.education.map(edu => (
    <div class="resume-item">
      <div class="resume-header">
        <h3>{edu.degree}</h3>
        <span class="company">{edu.school}</span>
      </div>
      <span class="period">{edu.period}</span>
      <p>{edu.description}</p>
    </div>
  ))}

  <h2>🛡 Skills</h2>
  {Object.entries(resume.skills).map(([category, items]) => (
    <div class="skill-group">
      <h3>{category}</h3>
      <div class="skill-tags">
        {items.map(item => <span class="skill-tag">{item}</span>)}
      </div>
    </div>
  ))}
</BaseLayout>

<style>
  .download-link {
    margin-bottom: 2rem;
  }

  .download-link a {
    display: inline-block;
    background: var(--bg-deep);
    border: 1px solid var(--accent);
    padding: 0.6rem 1.25rem;
    font-size: 1.1rem;
    transition: all 0.15s ease;
  }

  .download-link a:hover {
    background: var(--accent);
    color: var(--bg-deep) !important;
    text-decoration: none;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
  }

  .resume-item {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid var(--accent-2);
  }

  .resume-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .resume-header h3 {
    margin: 0 !important;
    color: var(--text-bright) !important;
  }

  .company {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .period {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--accent);
    display: block;
    margin: 0.25rem 0 0.5rem;
  }

  .skill-group {
    margin-bottom: 1rem;
  }

  .skill-group h3 {
    color: var(--accent-2-glow) !important;
    margin-bottom: 0.4rem !important;
  }

  .skill-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .skill-tag {
    background: var(--bg-deep);
    color: var(--text);
    padding: 0.25rem 0.65rem;
    border: 1px solid var(--border-bright);
    font-size: 1rem;
  }
</style>
