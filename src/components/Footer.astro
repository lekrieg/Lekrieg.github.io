---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <span class="footer-glyph">◆</span>
    <p>© {year} Daniel Henrique · Game Developer</p>
    <p class="footer-sub">Forged with Astro · Hosted on GitHub Pages</p>
    <span class="footer-glyph">◆</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-card);
    border-top: 2px solid var(--border-bright);
    padding: 1.5rem 1rem;
    color: var(--text-muted);
    text-align: center;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-glyph {
    color: var(--accent);
    font-size: 0.8rem;
  }

  .footer-sub {
    font-size: 0.95rem;
    color: var(--accent-2);
    opacity: 0.7;
  }
</style>
